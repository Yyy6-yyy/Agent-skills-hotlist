# Optional but recommended for higher rate limits and official APIs.
GITHUB_TOKEN=

# Skills.sh official API requires a Vercel OIDC token or equivalent token.
# On Vercel, prefer VERCEL_OIDC_TOKEN from @vercel/oidc.
SKILLS_SH_TOKEN=
VERCEL_OIDC_TOKEN=

# Smithery registry API key:
# https://smithery.ai/account/api-keys
SMITHERY_API_KEY=
